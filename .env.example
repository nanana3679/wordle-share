# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 좋아요 IP 해시 salt (ADR 0002) — 회전 시 기존 좋아요 전부 무효화. 영구 고정.
IP_HASH_SALT=

# 사이트 절대 URL — OG/sitemap/robots 생성 기준 (미설정 시 VERCEL_URL fallback)
NEXT_PUBLIC_SITE_URL=

# 신고 자동 가림 임계치 (ADR 0013) — 미설정 시 덱 5 / 댓글 3
REPORT_THRESHOLD_DECK=5
REPORT_THRESHOLD_COMMENT=3
# 자동 가림 시 운영자 알림 webhook (선택)
MODERATION_WEBHOOK_URL=

# 운영자 시드 API 토큰 (ADR 0011) — bot_* nick으로 POST /api/decks 호출 시 x-bot-token 헤더에 사용
BOT_SEED_TOKEN=
